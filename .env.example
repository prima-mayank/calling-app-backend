PORT=5000
# Comma-separated origins, or * to allow all.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Shared auth token for frontend/agent socket connections (optional but recommended in production).
REMOTE_CONTROL_TOKEN=

# Optional: absolute path to local host app bundle for backend download endpoint.
# HOST_APP_LOCAL_ZIP_PATH=C:\path\to\host-app-win.zip

# Optional: allow remote control from same machine/network id.
# ALLOW_SAME_MACHINE_REMOTE=0

# Optional: enable remote debug logs.
# REMOTE_DEBUG=0

# Optional: direct call ringing timeout in ms.
# DIRECT_CALL_TIMEOUT_MS=30000

# Optional auth/database layer (disabled by default to preserve current link-call flow).
# Set AUTH_ENABLED=1 to enable auth routes.
# AUTH_ENABLED=0
# AUTH_JWT_SECRET=replace-with-long-random-secret
# AUTH_JWT_EXPIRES_IN=7d
# AUTH_BCRYPT_ROUNDS=12
# AUTH_RELAXED_VALIDATION=0
# MONGODB_URI=mongodb://127.0.0.1:27017/calling-app
# MONGODB_AUTO_INDEX=0
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
# MONGODB_MAX_POOL_SIZE=10
